PORT=4000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=ghostdrop_proto

PBKDF2_ITERATIONS=250000
SUB_TOKEN_SECRET_KEY=replace_with_64_hex_or_high_entropy_secret
MAX_FILE_SIZE_MB=0
MAX_FILES_PER_UPLOAD=5000
MAX_VAULT_SIZE_MB=250
MAX_TOTAL_SYSTEM_SIZE_MB=14336
BATCH_DOWNLOAD_MAX_FILES=10

# Absolute or relative path to service account JSON key file.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service_account.json

# Google Drive folder ID (or full Drive folder URL).
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id


# Security storage backend: memory | redis
SECURITY_STORE=memory
REDIS_URL=redis://127.0.0.1:6379

# CAPTCHA provider: math | hcaptcha | recaptcha
CAPTCHA_PROVIDER=math
CAPTCHA_ALLOW_MATH_FALLBACK=true
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Comma-separated risk lists (IP reputation inputs)
RISK_BAD_IPS=
RISK_TOR_IPS=
RISK_VPN_IPS=
# Optional JSON overrides for policy tables
# Example: {"files.download":{"minute":15,"day":200},"default":{"minute":20,"day":300}}
ROUTE_RATE_LIMITS_JSON=
# Example: {"vault.access":{"captchaThreshold":30,"blockThreshold":85},"default":{"captchaThreshold":45,"blockThreshold":90}}
ROUTE_RISK_POLICY_JSON=

