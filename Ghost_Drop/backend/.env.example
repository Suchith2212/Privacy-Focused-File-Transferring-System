PORT=4000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=ghostdrop_proto

PBKDF2_ITERATIONS=250000
MAX_FILE_SIZE_MB=0
MAX_FILES_PER_UPLOAD=5000
MAX_VAULT_SIZE_MB=250
MAX_TOTAL_SYSTEM_SIZE_MB=14336

# Absolute or relative path to service account JSON key file.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service_account.json

# Google Drive folder ID (or full Drive folder URL).
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id

